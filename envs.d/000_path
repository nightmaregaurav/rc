# this file is named 000_path to make sure it is sourced first
# path setup
# if PREFIX is set, then start start the root paths with that instead of /
if [ -n "$PREFIX" ]; then
    ROOT="${PREFIX%/}"
else
    ROOT=""
fi

append_path() {
    PATH="${PATH:+$PATH:}$1"
}

append_path "$HOME/.flutter/bin"
append_path "$HOME/.config/composer/vendor/bin"
append_path "$HOME/.dotnet/tools"
append_path "$HOME/.dotnet"
append_path "$HOME/.local/share/JetBrains/Toolbox/scripts"
append_path "$HOME/Library/Application Support/JetBrains/Toolbox/scripts"
append_path "$HOME/.local/share/bin"
append_path "$HOME/.local/bin"
append_path "$HOME/local/bin"
append_path "$HOME/bin"
append_path "$ROOT/opt/mssql-tools/bin"
append_path "$ROOT/opt/homebrew/bin"
append_path "$ROOT/opt/homebrew/sbin"
append_path "$ROOT/usr/local/bin"
append_path "$ROOT/usr/local/sbin"
append_path "$ROOT/usr/bin/core_perl"
append_path "$ROOT/usr/bin/vendor_perl"
append_path "$ROOT/usr/bin/site_perl"
append_path "$ROOT/usr/bin"
append_path "$ROOT/usr/sbin"
append_path "$ROOT/bin"
append_path "$ROOT/sbin"

export PATH

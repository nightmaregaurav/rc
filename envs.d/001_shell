# this file is named 001_shell to make sure it is sourced second
# current shell setup
shell_from_ps=$(ps -p $$ -o comm= 2>/dev/null || echo "")
if [ -n "${BASH_VERSION:-}" ]; then
    export CURRENT_SHELL=$(which bash)
elif [ -n "${ZSH_VERSION}" ]; then
    export CURRENT_SHELL=$(which zsh)
elif [ -n "${KSH_VERSION:-}" ]; then
    export CURRENT_SHELL=$(which ksh)
elif [ -n "${shell_from_ps}" ]; then
    export CURRENT_SHELL="/bin/sh"
else
    export CURRENT_SHELL="$shell_from_ps"
fi

# Hide EOL sign ('%')
PROMPT_EOL_MARK=""

# Configure `time` format
TIMEFMT=$'\nreal\t%E\nuser\t%U\nsys\t%S\ncpu\t%P'

# Expand the history size
export HISTFILESIZE=10000
export SAVEHIST=10000
export HISTSIZE=2000

# Set history file
export HISTFILE="$HOME/.history"

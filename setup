#!/usr/bin/env bash

SCRIPT=$(basename "$0")

# If running in Termux, make sudo a no-op
if [ -n "$PREFIX" ]; then
  sudo() {
    # ignore common sudo flags if present
    while [ "$1" = "-n" ] || [ "$1" = "-H" ] || [ "$1" = "-E" ]; do
      shift
    done
    "$@"
  }
fi

HELP_MESSAGE="Usage: $SCRIPT

Clones rc, sets up the required environment, and sources it to the shell configuration file.

options:
  -h, --help    Show help message and exit."

# Help message
if [[ "$1" == "--help" || "$1" == "-h" ]]; then
  echo "$HELP_MESSAGE"
  exit 0
fi

set -euo pipefail

# Get current user and group
start_dir=$(pwd)
USER=$(whoami)
GROUP=$(id -gn "$USER")

if [ -n "$PREFIX" ]; then
    echo "Running in Termux. Will use $PREFIX as the root directory."
    ROOT_DIR="$PREFIX"
else
    echo "Running in native environment. Will use / as the root directory."
    ROOT_DIR=""
fi

echo "Preparing $ROOT_DIR/opt/rc directory..."
sudo mkdir -p $ROOT_DIR/opt/rc

if [ -n "$PREFIX" ]; then
    echo "Running in Termux. No need to change ownership or set permissions."
else
    # Set ownership of $ROOT_DIR/opt/rc to root:<current group>
    echo "Changing ownership of $ROOT_DIR/opt/rc to root:$GROUP..."
    sudo chown -R root:"$GROUP" $ROOT_DIR/opt/rc

    # Set group write permissions on $ROOT_DIR/opt/rc
    echo "Setting group write permissions on $ROOT_DIR/opt/rc..."
    sudo chmod -R g+rw $ROOT_DIR/opt/rc
fi

# Clone the rc repository
echo "Preparing to clone rc repository..."
cd $ROOT_DIR/opt/rc
if [ -d .git ]; then
    echo "rc repository already exists. Pulling latest changes..."
    git pull
else
    echo "Cloning rc repository..."
    git clone https://github.com/nightmaregaurav/rc.git .
    git config --global --add safe.directory $ROOT_DIR/opt/rc
fi

# Write source line to shell rc files
echo "Writing source line to shell profile..."
if [ -f $ROOT_DIR/etc/profile ]; then
    if ! grep -Fxq "source $ROOT_DIR/opt/rc/activate" $ROOT_DIR/etc/profile; then
        echo "source $ROOT_DIR/opt/rc/activate" | sudo tee -a $ROOT_DIR/etc/profile > /dev/null
    fi
fi

if [ -f $ROOT_DIR/etc/zprofile ]; then
    if ! grep -Fxq "source $ROOT_DIR/opt/rc/activate" $ROOT_DIR/etc/zprofile; then
        echo "source $ROOT_DIR/opt/rc/activate" | sudo tee -a $ROOT_DIR/etc/zprofile > /dev/null
    fi
fi

# Source the activate script in the current shell
set +euo pipefail
echo "Sourcing activate script directly to activate rc in the current shell..."
source $ROOT_DIR/opt/rc/activate

# Continue with the rest of your setup (e.g., install uv and other tools)
set -euo pipefail
cd "$start_dir"
echo "Setting up uv..."
echo "Detecting operating system..."
OS="$(uname -s)"
case "$OS" in
    Darwin)
        echo "Detected macOS."
        if ! command -v brew >/dev/null 2>&1; then
            echo "Homebrew not found. Please install Homebrew first: https://brew.sh/"
            exit 1
        fi
        echo "Installing uv with Homebrew..."
        brew install uv
        ;;

    Linux)
        set +u
        if [[ -n "$TERMUX_VERSION" ]]; then
            echo "Detected Android (Termux)."
            echo "Installing uv with pkg..."
            pkg install uv
        else
            echo "Detected Linux."
            echo "Installing uv with curl..."
            curl -LsSf https://astral.sh/uv/install.sh | sh
        fi
        set -u
        ;;

    MINGW*|MSYS*|CYGWIN*|Windows_NT)
        echo "Detected Windows."
        if ! command -v winget >/dev/null 2>&1; then
            echo "winget not found. Please make sure you're running this in a Windows environment with winget available."
            exit 1
        fi
        echo "Installing uv with winget..."
        winget install --id=astral-sh.uv -e --source winget
        ;;

    *)
        echo "Unsupported OS: $OS"
        exit 1
        ;;
esac

echo "Installing Python versions 3.13 and 3.14 using uv..."
uv python install 3.13
uv python install 3.14
echo "Installing argcomplete package using uv..."
uv tool install argcomplete
echo "Setup completed successfully."

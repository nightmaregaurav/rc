#!/usr/bin/env -S uv run --script

# /// script
# requires-python = ">=3.13"
# dependencies = [
#   "argcomplete",
#   "docker",
# ]
# ///

import argparse
import argcomplete
import docker
import sys


def parse_mapping(mapping: str):
    try:
        container, host_port, container_port = mapping.split(":")
        return container, int(host_port), int(container_port)
    except ValueError:
        raise ValueError(
            "Invalid format. Expected: <containerName>:<hostPort>:<containerPort>"
        )


def ensure_image(client, image_name: str):
    try:
        client.images.get(image_name)
    except docker.errors.ImageNotFound:
        print(f"Pulling image: {image_name}")
        client.images.pull(image_name)


def get_container(client, identifier: str):
    try:
        return client.containers.get(identifier)
    except docker.errors.NotFound:
        raise RuntimeError(f"Container '{identifier}' not found.")


def get_forwarder_name(stable_name: str, host_port: int, container_port: int):
    return f"port-forwarder-{stable_name}-{host_port}-{container_port}"


def container_exists(client, name: str):
    try:
        return client.containers.get(name)
    except docker.errors.NotFound:
        return None


def create_forwarder(client, target_container_obj, host_port: int, container_port: int):
    stable_name = target_container_obj.name
    forwarder_name = get_forwarder_name(stable_name, host_port, container_port)

    existing = container_exists(client, forwarder_name)
    if existing:
        print(f"Forwarder already exists: {forwarder_name}")
        return existing

    ensure_image(client, "alpine/socat")

    command = [
        f"tcp-listen:{container_port},fork,reuseaddr",
        f"tcp-connect:127.0.0.1:{container_port}",
    ]

    print(f"Creating forwarder: {forwarder_name}")

    container = client.containers.run(
        "alpine/socat",
        command,
        name=forwarder_name,
        detach=True,
        network_mode=f"container:{target_container_obj.id}",
        ports={f"{container_port}/tcp": host_port},
        restart_policy={"Name": "unless-stopped"},
    )

    return container


def remove_forwarder(client, target_container_obj, host_port: int, container_port: int):
    stable_name = target_container_obj.name
    forwarder_name = get_forwarder_name(stable_name, host_port, container_port)

    existing = container_exists(client, forwarder_name)
    if not existing:
        print(f"No forwarder found: {forwarder_name}")
        return

    print(f"Stopping forwarder: {forwarder_name}")
    try:
        existing.stop(timeout=5)
    except Exception:
        pass

    print(f"Removing forwarder: {forwarder_name}")
    existing.remove()

    print("✅ Forwarder removed")


def validate_running(container):
    if container.status != "running":
        raise RuntimeError(f"Target container '{container.name}' is not running.")


def main():
    parser = argparse.ArgumentParser(
        description="Expose or remove a port from an existing Docker container without modifying compose.",
        formatter_class=argparse.RawTextHelpFormatter,
        add_help=False,
    )

    parser.add_argument(
        "mapping",
        help="Format: <containerName|id>:<hostPort>:<containerPort>",
    )

    parser.add_argument(
        "-r", "--rm",
        action="store_true",
        help="Remove the forwarder instead of creating it.",
    )

    parser.add_argument("-h", "--help", action="help", help="Show help message and exit.")

    argcomplete.autocomplete(parser, always_complete_options=False)
    args = parser.parse_args()

    try:
        container_identifier, host_port, container_port = parse_mapping(args.mapping)
    except ValueError as e:
        print(e)
        sys.exit(1)

    client = docker.from_env()

    try:
        target_container = get_container(client, container_identifier)
    except RuntimeError as e:
        print(e)
        sys.exit(1)

    try:
        if args.rm:
            remove_forwarder(client, target_container, host_port, container_port)
            return

        validate_running(target_container)

        container = create_forwarder(
            client,
            target_container,
            host_port,
            container_port,
        )

    except Exception as e:
        print(f"Error: {e}")
        sys.exit(1)

    print("\n✅ Forwarding active")
    print(f"Host:       localhost:{host_port}")
    print(f"Container:  {target_container.name}:{container_port}")
    print(f"Forwarder:  {container.name}")


if __name__ == "__main__":
    main()

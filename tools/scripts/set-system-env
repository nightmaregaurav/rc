#!/usr/bin/env -S uv run --script

# /// script
# requires-python = ">=3.13"
# dependencies = [
#     "argcomplete",
# ]
# ///

import argparse
import sys
from pathlib import Path
import argcomplete
import platform

ENV_FILE = Path("/etc/environment")


def load_env():
    env = {}
    if ENV_FILE.exists():
        for line in ENV_FILE.read_text().splitlines():
            if "=" in line:
                k, v = line.split("=", 1)
                env[k] = v
    return env


def save_env(env: dict):
    lines = [f"{k}={v}" for k, v in env.items()]
    ENV_FILE.write_text("\n".join(lines) + "\n")


def main():
    parser = argparse.ArgumentParser(
        description="Set system-wide environment variable in /etc/environment safely",
        formatter_class=argparse.RawTextHelpFormatter,
        add_help=False,
    )

    parser.add_argument("-N", "--name", required=True, help="Environment variable name")
    parser.add_argument("-V", "--value", required=True, help="Environment variable value")
    parser.add_argument("-F", "--force", action="store_true", help="Overwrite if variable already exists")

    parser.add_argument(
        "-h", "--help",
        action="help",
        help="Show help message and exit.",
    )

    argcomplete.autocomplete(parser, always_complete_options=False)
    args = parser.parse_args()

    if platform.system() != "Linux":
        print("❌ This tool only works on Linux (uses /etc/environment).", file=sys.stderr)
        sys.exit(2)

    env = load_env()

    if args.name in env:
        if not args.force:
            print(f"❌ Variable '{args.name}' already exists.", file=sys.stderr)
            print(f"   Current value: {env[args.name]}", file=sys.stderr)
            print("   Use --force to overwrite.", file=sys.stderr)
            sys.exit(1)
        else:
            old_value = env[args.name]
            env[args.name] = args.value
            save_env(env)
            print(f"⚠️  Overwritten '{args.name}'")
            print(f"   Old: {old_value}")
            print(f"   New: {args.value}")
    else:
        env[args.name] = args.value
        save_env(env)
        print(f"✅ Added '{args.name}'")


if __name__ == "__main__":
    main()
